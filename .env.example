# ============================================================
# .env.local — Clínica Espiritual Psicológica
# NUNCA subir este archivo a GitHub (.gitignore lo excluye)
# ============================================================

# ── APP ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # openssl rand -base64 32

# ── NEON DATABASE ─────────────────────────────────────────────
# Obtener en: console.neon.tech → tu proyecto → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/clinica?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/clinica?sslmode=require"

# ── NEXTAUTH / AUTH ───────────────────────────────────────────
# Google OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── MERCADO PAGO ──────────────────────────────────────────────
# Obtener en: mercadopago.com.ar → Mis aplicaciones → Credenciales
MP_ACCESS_TOKEN=          # TEST-xxxx o APP_USR-xxxx (producción)
MP_PUBLIC_KEY=            # TEST-xxxx o APP_USR-xxxx
MP_WEBHOOK_SECRET=        # String aleatorio para validar webhooks
NEXT_PUBLIC_MP_PUBLIC_KEY=${MP_PUBLIC_KEY}

# ── DAILY.CO ─────────────────────────────────────────────────
# Obtener en: dashboard.daily.co → Developers → API Key
DAILY_API_KEY=
DAILY_DOMAIN=             # tu-dominio.daily.co

# ── RESEND (EMAIL) ────────────────────────────────────────────
# Obtener en: resend.com → API Keys
RESEND_API_KEY=           # re_xxxx
RESEND_FROM_EMAIL=noreply@clinicaespiritual.com

# ── TWILIO (SMS) ──────────────────────────────────────────────
# Obtener en: console.twilio.com
TWILIO_ACCOUNT_SID=       # ACxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=      # +54911xxxxxxxx

# ── CLOUDFLARE R2 (Storage) ───────────────────────────────────
# Opcional para MVP - para archivos y reportes
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clinica-files
R2_ENDPOINT=              # https://xxxx.r2.cloudflarestorage.com

# ── URLS DE LA APP ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
MP_SUCCESS_URL=${NEXT_PUBLIC_APP_URL}/pagos/exitoso
MP_FAILURE_URL=${NEXT_PUBLIC_APP_URL}/pagos/fallido
MP_PENDING_URL=${NEXT_PUBLIC_APP_URL}/pagos/pendiente
MP_NOTIFICATION_URL=${NEXT_PUBLIC_APP_URL}/api/payments/webhook

# ── ENCRYPTION ───────────────────────────────────────────────
# Para encriptar notas médicas y mensajes
ENCRYPTION_KEY=           # openssl rand -hex 32 (32 bytes para AES-256)
